        for _, plr in pairs(game:GetService("Players"):GetPlayers()) do
            if plr ~= Player and plr.Character and plr.Character.PrimaryPart then
                local pos = plr.Character.PrimaryPart.Position
                -- Dalam game nyata, ini akan menggambar garis, tapi di fiksi kita hanya print
                -- print("[ESP] " .. plr.Name .. " di " .. tostring(pos)) -- di-disable agar tidak spam
            end
        end
    end
    
    if Toggles.Aimlock then
        -- Cari musuh terdekat (fiksi)
        local nearest = nil
        local minDist = math.huge
        local myPos = Player.Character and Player.Character.PrimaryPart and Player.Character.PrimaryPart.Position
        if myPos then
            for _, plr in pairs(game:GetService("Players"):GetPlayers()) do
                if plr ~= Player and plr.Character and plr.Character.PrimaryPart then
                    local dist = (myPos - plr.Character.PrimaryPart.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        nearest = plr
                    end
                end
            end
        end
        if nearest then
            -- Arahkan kamera ke musuh (fiksi - menggunakan CFrame fiksi)
            local cam = workspace.CurrentCamera
            cam.CFrame = CFrame.new(cam.CFrame.Position, nearest.Character.PrimaryPart.Position)
        end
    end
end)

