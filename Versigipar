        btn.TextColor3 = Color3.new(1, 1, 1)
        btn.Parent = mainFrame
        
        btn.MouseButton1Click:Connect(function()
            Toggles[name] = not Toggles[name]
            btn.Text = name .. (Toggles[name] and " [ON]" or " [OFF]")
            btn.BackgroundColor3 = Toggles[name] and Color3.new(0.3, 0.6, 0.2) or Color3.new(0.2, 0.2, 0.3)
            
            -- Kirim sinyal ke remote fiksi (tidak ada di dunia nyata)
            if VirtualRemote then
                VirtualRemote:FireServer("ToggleCheat", name, Toggles[name])
            end
            print("[Wasteland] " .. name .. " diubah menjadi " .. tostring(Toggles[name]))
        end)
        yOffset = yOffset + 35
    end
    
    -- Slider kecepatan (fiksi)
    local sliderLabel = Instance.new("TextLabel")
    sliderLabel.Size = UDim2.new(0.9, 0, 0, 20)
    sliderLabel.Position = UDim2.new(0.05, 0, 0, yOffset)
    sliderLabel.BackgroundTransparency = 1
    sliderLabel.Text = "Fly Speed: 50"
    sliderLabel.TextColor3 = Color3.new(1, 1, 1)
    sliderLabel.Parent = mainFrame
    yOffset = yOffset + 25
    
    local slider = Instance.new("TextBox")
    slider.Size = UDim2.new(0.9, 0, 0, 25)
    slider.Position = UDim2.new(0.05, 0, 0, yOffset)
    slider.BackgroundColor3 = Color3.new(0.2, 0.2, 0.3)
    slider.Text = "50"
    slider.TextColor3 = Color3.new(1, 1, 1)
    slider.Parent = mainFrame
    
    slider:GetPropertyChangedSignal("Text"):Connect(function()
        local num = tonumber(slider.Text)
        if num then
            flySpeed = math.clamp(num, 10, 500)
            sliderLabel.Text = "Fly Speed: " .. flySpeed
        end
    end)
end

-- ============================================
-- FUNGSI FLY (Fiksi - menggunakan WastelandEngine)
-- ============================================
local function FlyUpdate()
    if not Toggles.Fly then return end
    local char = Player.Character
    if not char or not char.PrimaryPart then return end
    local hrp = char.PrimaryPart
    
    -- Menggunakan service fiksi 'WastelandEngine' (tidak ada di Roblox)
    if WastelandEngine.Fly then
        WastelandEngine.Fly(hrp, flySpeed)
    else
        -- Simulasi fiksi: mengubah posisi dengan Vector3
        local moveDirection = Vector3.new(0, 0, 0)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDirection = hrp.CFrame.LookVector * flySpeed end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDirection = -hrp.CFrame.LookVector * flySpeed end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDirection = -hrp.CFrame.RightVector * flySpeed end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDirection = hrp.CFrame.RightVector * flySpeed end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDirection = moveDirection + Vector3.new(0, flySpeed, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDirection = moveDirection - Vector3.new(0, flySpeed, 0) end
        
        -- Perpindahan posisi (fiksi, tidak akan bekerja di game nyata karena velocity tidak di-set)
        hrp.Position = hrp.Position + moveDirection * RunService.RenderStepped:Wait()
    end
end

-- ============================================
-- FUNGSI SPEED & INFINITE JUMP (Fiksi)
-- ============================================
RunService.RenderStepped:Connect(function()
    local char = Player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    -- Speed Hack (fiksi - memodifikasi WalkSpeed, yang di game nyata sering dilindungi)
    if Toggles.Speed then
        hum.WalkSpeed = walkSpeedBoost
    else
        hum.WalkSpeed = 16 -- default
    end
    
    -- Infinite Jump (fiksi - mengubah JumpPower)
    if Toggles.InfiniteJump then
        hum.JumpPower = 100
        -- Event fiksi: Reset jump count tiap kali mendarat
        hum:GetPropertyChangedSignal("Jump"):Connect(function()
            -- Logika fiksi
        end)
    else
        hum.JumpPower = 50
    end
end)

